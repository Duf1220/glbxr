{
  "version": 2,
  "builds": [
    { "src": "api/glb.js", "use": "@vercel/node" },
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "qr.png", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/glb", "dest": "/api/glb.js" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}
